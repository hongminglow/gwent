{
  "name": "oathbound",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build && npm run dist:compress",
    "preview": "vite preview --host 127.0.0.1",
    "dist:compress": "node scripts/compress-dist.mjs",
    "analyze:bundle": "node scripts/analyze-dist.mjs",
    "package:verify": "npm run lint && npm run test && npm run validate:data && npm run build && npm run analyze:bundle",
    "test": "vitest run",
    "validate:data": "vitest run src/game/data/cardData.test.ts",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "three": "^0.164.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.3.0",
    "@types/three": "^0.164.0",
    "eslint": "^9.3.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.32.0",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  }
}
